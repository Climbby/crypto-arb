# Server
HOST=0.0.0.0
PORT=8000

# Scanner
POLL_INTERVAL_SECONDS=1
MIN_NET_EDGE_PCT=0.05
SLIPPAGE_BPS=5
WATCHED_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
EXCHANGES=binance,kraken,coinbase

# Fees (fraction of notional, e.g. 0.001 = 0.1%)
FEE_BINANCE=0.001
FEE_KRAKEN=0.0026
FEE_COINBASE=0.006

# Paper trading
PAPER_STARTING_USDT=10000
AUTO_PAPER_ENABLED=true
AUTO_PAPER_NOTIONAL_USDT=400
# Leave unset to use MIN_NET_EDGE_PCT for auto fills
# AUTO_PAPER_MIN_NET_EDGE_PCT=0.1
AUTO_PAPER_COOLDOWN_SECONDS=12
AUTO_PAPER_MAX_PER_SCAN=3
AUTO_PAPER_MAX_PER_MINUTE=20
AUTO_REBALANCE_ENABLED=true
AUTO_REBALANCE_COOLDOWN_SECONDS=20
AUTO_REBALANCE_USDT_CHUNK=500
DB_PATH=data/crypto_arb.db

# Optional: exchange API keys (not required for v1 public scanning)
# BINANCE_API_KEY=
# BINANCE_SECRET=
